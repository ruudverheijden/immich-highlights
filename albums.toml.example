# Configure rolling time-based highlight albums.
#
# Copy this file to albums.toml for local runs, or mount your own file to
# /app/albums.toml in Docker.

[[albums]]
name = "Highlights: Last Week"
bucket = "last-week"
window_days = 7
limit = 15
max_candidates = 100
enabled = true

[[albums]]
name = "Highlights: Last Month"
bucket = "last-month"
window_days = 30
limit = 15
max_candidates = 100
enabled = true

[[albums]]
name = "Highlights: Last Year"
bucket = "last-year"
window_days = 365
limit = 15
max_candidates = 100
enabled = true

# Optional smart-search filters for content that should be penalized.
# These run inside the same time window as each album rule.

[[content_filters]]
label = "screenshot"
query = "screenshot"
penalty = -40
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "paperwork"
query = "document paperwork form letter contract"
penalty = -25
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "whiteboard"
query = "whiteboard presentation slide notes"
penalty = -15
max_results = 15
min_search_pool = 500
enabled = true

[[content_filters]]
label = "receipt"
query = "receipt invoice bill payment slip"
penalty = -30
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "product-photo"
query = "product packaging label barcode"
penalty = -20
max_results = 20
min_search_pool = 500
enabled = true

[[content_filters]]
label = "food-menu"
query = "restaurant menu food menu menu card"
penalty = -20
max_results = 20
min_search_pool = 500
enabled = true

[[content_filters]]
label = "shopping"
query = "store shelf price tag shopping product display"
penalty = -15
max_results = 20
min_search_pool = 500
enabled = true
