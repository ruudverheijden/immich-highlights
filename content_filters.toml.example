# Configure optional smart-search filters for content that is usually not a
# highlight photo. Most users can keep this file unchanged.
#
# Copy this file to content_filters.toml for local runs, or mount your own file
# to /app/content_filters.toml in Docker.

[[content_filters]]
label = "screenshot"
query = "screenshot"
penalty = -40
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "paperwork"
query = "document paperwork form letter contract"
penalty = -25
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "whiteboard"
query = "whiteboard presentation slide notes"
penalty = -15
max_results = 15
min_search_pool = 500
enabled = true

[[content_filters]]
label = "receipt"
query = "receipt invoice bill payment slip"
penalty = -30
max_results = 25
min_search_pool = 500
enabled = true

[[content_filters]]
label = "product-photo"
query = "product packaging label barcode"
penalty = -20
max_results = 20
min_search_pool = 500
enabled = true

[[content_filters]]
label = "food-menu"
query = "restaurant menu food menu menu card"
penalty = -20
max_results = 20
min_search_pool = 500
enabled = true

[[content_filters]]
label = "shopping"
query = "store shelf price tag shopping product display"
penalty = -15
max_results = 20
min_search_pool = 500
enabled = true
