# Immich API Configuration
# Use the Immich base URL as opened in your browser. The app adds /api internally.
IMMICH_API_URL=http://immich:2283
IMMICH_API_KEY=your_immich_api_key_here

# Scorer Configuration
SCORER_DRY_RUN=true
SCORER_DB_PATH=./db/scorer.db
SCORER_SCAN_INTERVAL_HOURS=24
SCORER_MAX_ASSETS=100
SCORER_BUCKET=MVP
SCORER_TEMP_DIR=/tmp/scorer
SCORER_LOG_LEVEL=INFO
SCORER_ALBUM_CONFIG_PATH=./albums.toml
SCORER_CONTENT_FILTER_CONFIG_PATH=./content_filters.toml
SCORER_SCORING_CONFIG_PATH=./scoring.toml
